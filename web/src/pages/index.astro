---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import MetricBand from '../components/metrics/MetricBand.astro';
import ExpertiseGrid from '../components/expertise/ExpertiseGrid.astro';
import ClientMarquee from '../components/clients/ClientMarquee.astro';
import { useTranslations, withBase } from '../i18n/ui';

const lang = 'es' as const;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t.meta.homeTitle} description={t.meta.homeDesc} path="/">
  <Hero hero={t.hero}>
    <MetricBand slot="metrics" metrics={t.metrics} />
  </Hero>

  <!-- Perfil -->
  <section class="sec" id="perfil" aria-labelledby="perfil-h">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">{t.perfil.tag}</span>
        <h2 id="perfil-h" set:html={t.perfil.heading} />
        <p class="lead" set:html={t.perfil.lead}></p>
      </div>
      <div class="grid-3">
        {
          t.perfil.cards.map((card) => (
            <div class="card">
              <div class="idx">{card.idx}</div>
              <h3>{card.title}</h3>
              <p style="color:var(--text-dim)">{card.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="sec" id="expertise" aria-labelledby="expertise-h">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">{t.expertise.tag}</span>
        <h2 id="expertise-h">{t.expertise.heading}</h2>
      </div>
      <ExpertiseGrid groups={t.expertise.groups} />
    </div>
  </section>

  <!-- Trayectoria teaser -->
  <section class="sec" id="trayectoria" aria-labelledby="tray-h">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">{t.trayectoria.tag}</span>
        <h2 id="tray-h">{t.trayectoria.heading}</h2>
      </div>
      <div class="grid-3">
        {
          t.trayectoria.items.slice(0, 3).map((item) => (
            <div class="card">
              <div class="idx">{item.dates}</div>
              <h3>{item.company}</h3>
              <p style="color:var(--text-dim)">{item.role}</p>
            </div>
          ))
        }
      </div>
      <p style="margin-top:1.8rem">
        <a href={withBase('/trayectoria')} class="btn btn-ghost">{t.trayectoria.teaserCta}</a>
      </p>
    </div>
  </section>

  <!-- Clientes -->
  <section class="sec" id="clientes" aria-labelledby="clientes-h">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">{t.clients.tag}</span>
        <h2 id="clientes-h">{t.clients.heading}</h2>
      </div>
      <ClientMarquee clients={t.clients.list} />
    </div>
  </section>

  <!-- Contacto CTA -->
  <section class="contact cta-band" aria-labelledby="cta-h">
    <div class="wrap reveal">
      <span class="sec-tag">{t.contacto.tag}</span>
      <h2 id="cta-h" style="margin-top:1rem">{t.contacto.heading}</h2>
      <p class="lead">{t.contacto.lead}</p>
      <div class="contact-links">
        <a href={withBase('/contacto')} class="btn btn-primary">{t.hero.ctaPrimary.label}</a>
        <a href={t.contacto.linkedinHref} target="_blank" rel="noopener" class="btn btn-ghost">{t.contacto.linkedinLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
