---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Timeline from '../../components/timeline/Timeline.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
const { education, certification } = t.trayectoria;
---

<BaseLayout lang={lang} title={t.meta.trayectoriaTitle} description={t.meta.trayectoriaDesc} path="/en/trayectoria">
  <section class="sec" id="experiencia" aria-labelledby="exp-h">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">{t.trayectoria.tag}</span>
        <h2 id="exp-h">{t.trayectoria.heading}</h2>
      </div>
      <Timeline items={t.trayectoria.items} />
    </div>
  </section>

  <section class="sec" aria-label="Education and certification">
    <div class="wrap reveal">
      <div class="grid-2">
        <div class="card">
          <div class="idx">{education.idx}</div>
          <h3>{education.title}</h3>
          <p style="color:var(--text-dim)">{education.body}</p>
        </div>
        <div class="card">
          <div class="idx">{certification.idx}</div>
          <h3>{certification.title}</h3>
          <p style="color:var(--text-dim)" set:html={certification.body}></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
