---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationCard from '../../components/publications/PublicationCard.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
const p = t.publicaciones;
---

<BaseLayout lang={lang} title={t.meta.publicacionesTitle} description={t.meta.publicacionesDesc} path="/en/publicaciones">
  <section class="sec" aria-labelledby="pub-h">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">{p.tag}</span>
        <h2 id="pub-h">{p.heading}</h2>
        <p class="lead">{p.lead}</p>
      </div>
      <div class="pub-list">
        {
          p.items.map((item) => (
            <PublicationCard
              idx={item.idx}
              title={item.title}
              subtitle={item.subtitle}
              role={item.role}
              meta={item.meta}
              summary={item.summary}
              tags={item.tags}
              href={`/en/publicaciones/${item.slug}`}
              readLabel={p.readLabel}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
